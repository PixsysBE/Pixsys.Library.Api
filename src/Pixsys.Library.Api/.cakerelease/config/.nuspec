<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>Pixsys.Library.Api</id>
    <title>Pixsys.Library.Api</title>
    <description>Helpers for API</description>
    <authors>Sylvain Signore</authors>
    <version>1.3.2.0</version>
    <readme>README.md</readme>
    <projectUrl>https://github.com/PixsysBE/Pixsys.Library.Api</projectUrl>
    <dependencies>
    <group targetFramework="net10.0">
	  <dependency id="Asp.Versioning.Http" version="10.0.0" />
      <dependency id="Asp.Versioning.Mvc" version="10.0.0" />
      <dependency id="Asp.Versioning.Mvc.ApiExplorer" version="10.0.0" />
      <dependency id="Microsoft.AspNetCore.Authentication.JwtBearer" version="10.0.9" />
    </group>
    </dependencies>   	
  </metadata>
  <files>
    <file src="bin\Release\net10.0\*.dll" target="lib\net10.0" />
    <file src="bin\Release\net10.0\*.xml" target="lib\net10.0" />
    <file src="..\..\..\README.md" target="README.md" />
  </files>
</package>